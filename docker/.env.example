# 复制本文件为 `docker/.env` 后按需修改（不要将含真实密码的 `.env` 提交到 Git）。

# 与 stockManager / carSales 等同机部署时必设，避免 Compose 项目名冲突（backend/frontend 服务名相同）
COMPOSE_PROJECT_NAME=astock

# --- 宿主机端口映射（可选）---
# 默认 8082 / 8002，避开 stockManager 8080/8000 与 carSales 8081/8001
FRONTEND_PUBLISH_PORT=8082
BACKEND_PUBLISH_PORT=8002

# --- SQLite（backend 服务）---
DB_PATH=/app/data/astock.db
SQLITE_HOST_DIR=./sqlite-data

# --- Redis（redis 服务）---
REDIS_URL=redis://redis:6379/0

# --- 后端日志与缓存（可选）---
LOG_LEVEL=INFO
LOG_DIR=/var/log/astock
# ASSET_PRICE_CACHE_TTL=86400
# MARKET_OVERVIEW_FAILURE_TTL=300
# CORS_ORIGINS=https://example.com,https://www.example.com

# --- 前端构建（写入 frontend 镜像，改后须 docker compose build frontend）---
VITE_ADMIN_REFRESH_PASSWORD=change-me

# --- Gunicorn（可选）---
# GUNICORN_WORKERS=2
# GUNICORN_TIMEOUT=300
# GUNICORN_LOG_LEVEL=info
