{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "strict": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "vite-plugin-eslint": ["node_modules/vite-plugin-eslint/dist/index.d.ts"]
    },
    "lib": ["es2020", "dom"],
    "types": ["vite/client"],
    "skipLibCheck": true
  },
  "include": ["src/**/*", "src/**/*.vue", "config/**/*.ts"],
  "exclude": ["node_modules"]
}
