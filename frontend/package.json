{
  "name": "Astock",
  "description": "Astock Frontend",
  "version": "1.0.0",
  "private": true,
  "author": "robin.zhangzc",
  "license": "MIT",
  "scripts": {
    "dev": "vite --config ./config/vite.config.dev.ts",
    "build": "vue-tsc --noEmit && vite build --config ./config/vite.config.prod.ts",
    "report": "cross-env REPORT=true pnpm run build",
    "preview": "pnpm run build && vite preview --host",
    "type:check": "vue-tsc --noEmit --skipLibCheck",
    "lint-staged": "lint-staged",
    "prepare": "cd .. && husky frontend/.husky || true"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.vue": [
      "stylelint --fix",
      "prettier --write",
      "eslint --fix"
    ],
    "*.{less,css}": [
      "stylelint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@arco-design/web-vue": "^2.58.0",
    "@vueuse/core": "^9.13.0",
    "axios": "^1.18.1",
    "mitt": "^3.0.1",
    "pinia": "^2.3.1",
    "vue": "^3.5.39",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@arco-plugins/vite-vue": "^1.4.6",
    "@commitlint/cli": "^17.8.1",
    "@commitlint/config-conventional": "^17.8.1",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitejs/plugin-vue-jsx": "^4.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^9.33.0",
    "husky": "^9.1.7",
    "less": "^4.6.7",
    "lint-staged": "^15.5.2",
    "postcss-html": "^1.8.1",
    "prettier": "^3.9.5",
    "rollup-plugin-visualizer": "^5.14.0",
    "stylelint": "^14.16.1",
    "stylelint-config-recommended": "9.0.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^29.0.0",
    "stylelint-order": "^5.0.0",
    "typescript": "^6.0.3",
    "unplugin-vue-components": "^28.8.0",
    "vite": "^6.4.3",
    "vite-plugin-eslint": "^1.8.1",
    "vite-svg-loader": "^5.1.1",
    "vue-tsc": "^3.3.7"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "overrides": {
      "stylelint-config-recommended": "9.0.0"
    }
  }
}
